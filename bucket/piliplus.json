{
    "version": "2.0.3.1",
    "description": "BiliBili 第三方客户端",
    "homepage": "https://github.com/bggRGjQaUbCoE/PiliPlus",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/2.0.3.1/PiliPlus_windows_2.0.3+4836_x64_portable.zip",
            "hash": "8167a7dc650173409ffa89ed824cff50dac800c5f520d9460d8ee872b5312c4d"
        }
    },
    "extract_dir": "PiliPlus-Win",
    "shortcuts": [
        [ "piliplus.exe", "PiliPlus" ]
    ],
    // --- 关键改进：使用内置的 persist 实现数据持久化 ---
    "persist": [
        ["AppData", "$env:AppData\\com.example\\piliplus"]
    ],
    // --- 如果确实要在安装前后关进程，直接写在 script 里，不要引用外部文件 ---
    "pre_uninstall": "Stop-Process -Name 'piliplus' -ErrorAction SilentlyContinue",
    
    "checkver": {
        "github": "https://github.com/bggRGjQaUbCoE/PiliPlus",
        "regex": "PiliPlus_windows_(?<main>[\\d.]+)%2B(?<build>\\d+)_x64"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/$version/PiliPlus_windows_$matchMain+$matchBuild_x64_portable.zip"
            }
        }
    }
}
